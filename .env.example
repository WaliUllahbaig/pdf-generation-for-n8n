# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False

# Python Configuration
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# API Configuration
API_HOST=0.0.0.0
API_PORT=5001

# Logging
LOG_LEVEL=INFO

# PDF Generation
MAX_PDF_SIZE_MB=10
MAX_PAYLOAD_SIZE_MB=50
PDF_TIMEOUT_SECONDS=120

# Docker/Orchestration
CONTAINER_NAME=html-to-pdf-api
SERVICE_NAME=html-to-pdf-api
